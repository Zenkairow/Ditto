{
  "manifest_version": 3,
  "name": "Ditto — Duplicate Your AI's Brain",
  "version": "1.0.0",
  "description": "Extract, scrub, and compress chaotic AI chats into a structured 7-Pillar Semantic Blueprint. Works with ChatGPT, Claude, Gemini, and any LLM.",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage"],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
